classDiagram
    direction TB

    %% ===== Go дҫ§: Wails з»‘е®ҡдё»з»“жһ„дҪ“ =====
    class App {
        -context.Context ctx
        +startup(ctx context.Context) void
        +shutdown() void
        +ClipboardWrite(text string) error
        +GetDataDir() string
        +GetToolList() []ToolMeta
        +GetAppVersion() string
        %% JSON е·Ҙе…·ж–№жі•
        +JsonFormat(input string, indent int) string, error
        +JsonMinify(input string) string, error
        +JsonValidate(input string) string, error
        %% Base64 е·Ҙе…·ж–№жі•
        +Base64EncodeText(input string) string, error
        +Base64DecodeText(input string) string, error
        +Base64EncodeFile(filePath string) string, error
        +Base64DecodeFile(filePath string, outputPath string) string, error
        %% ж—¶й—ҙжҲіе·Ҙе…·ж–№жі•
        +TimestampToDate(timestamp int64, unit string) string, error
        +DateToTimestamp(dateStr string, timezone string) int64, error
        +MultiTimezone(timestamp int64, unit string) []TimezoneResult, error
        %% YAML е·Ҙе…·ж–№жі•
        +YamlFormat(input string, indent int) string, error
        +YamlValidate(input string) string, error
        +YamlToJSON(input string) string, error
        %% XML е·Ҙе…·ж–№жі•
        +XmlFormat(input string, indent int) string, error
        +XmlMinify(input string) string, error
        +XmlValidate(input string) string, error
        %% йҡҸжңәеӯ—з¬ҰдёІе·Ҙе…·ж–№жі•
        +RandomGenerate(params RandomParams) []string, error
        %% Cron е·Ҙе…·ж–№жі•
        +CronParse(expression string) CronParseResult, error
        +CronValidate(expression string) string, error
        +CronNextN(expression string, count int) []string, error
    }

    %% ===== Go дҫ§: иҫ…еҠ©з»“жһ„дҪ“пјҲеҸӮж•°/иҝ”еӣһеҖјпјҢWails иҮӘеҠЁз”ҹжҲҗ TS зұ»еһӢпјү =====
    class RandomParams {
        +int length
        +map charsetFlags
        +int count
    }

    class TimezoneResult {
        +string zone
        +string dateStr
        +string offset
    }

    class CronParseResult {
        +string description
        +bool isValid
    }

    class ToolMeta {
        +string id
        +string name
        +string icon
        +string category
        +ActionDef[] actions
    }

    class ActionDef {
        +string action
        +string label
    }

    App --> RandomParams : receives as param
    App --> TimezoneResult : returns
    App --> CronParseResult : returns
    App --> ToolMeta : returns
    ToolMeta --> ActionDef : contains

    %% ===== Go дҫ§: pkg е·Ҙе…·еҢ…пјҲзәҜеҮҪж•°пјү =====
    class JsonUtil {
        +Format(input string, indent int) string, error
        +Minify(input string) string, error
        +Validate(input string) string, error
    }

    class Base64Util {
        +EncodeText(input string) string, error
        +DecodeText(input string) string, error
        +EncodeFile(filePath string) string, error
        +DecodeFile(filePath string, outputPath string) string, error
    }

    class FileUtil {
        +CheckSize(filePath string, limit int64) error
        +ReadFile(filePath string) []byte, error
        +WriteFile(filePath string, data []byte) error
    }

    class TimeUtil {
        +TimestampToDate(ts int64, unit string) string, error
        +DateToTimestamp(dateStr string, tz string) int64, error
        +MultiTimezone(ts int64, unit string) []TimezoneResult, error
    }

    class YamlUtil {
        +Format(input string, indent int) string, error
        +Validate(input string) string, error
        +ToJSON(input string) string, error
    }

    class XmlUtil {
        +Format(input string, indent int) string, error
        +Minify(input string) string, error
        +Validate(input string) string, error
    }

    class RandomUtil {
        +Generate(length int, charsetFlags map, count int) []string, error
    }

    class CronUtil {
        +Parse(expression string) CronParseResult, error
        +Validate(expression string) string, error
        +NextN(expression string, count int) []string, error
    }

    App --> JsonUtil : JsonFormatвҶ’Format, JsonMinifyвҶ’Minify, JsonValidateвҶ’Validate
    App --> Base64Util : Base64EncodeTextвҶ’EncodeText, Base64EncodeFileвҶ’EncodeFile
    App --> FileUtil : й—ҙжҺҘйҖҡиҝҮ Base64Util
    App --> TimeUtil : TimestampToDateвҶ’TimestampToDate, MultiTimezoneвҶ’MultiTimezone
    App --> YamlUtil : YamlFormatвҶ’Format, YamlToJSONвҶ’ToJSON
    App --> XmlUtil : XmlFormatвҶ’Format, XmlValidateвҶ’Validate
    App --> RandomUtil : RandomGenerateвҶ’Generate
    App --> CronUtil : CronParseвҶ’Parse, CronNextNвҶ’NextN

    %% ===== Wails иҮӘеҠЁз”ҹжҲҗеұӮ =====
    class WailsJSGoMainApp {
        <<generated>>
        +JsonFormat(input string, indent int) Promise~string~
        +JsonMinify(input string) Promise~string~
        +JsonValidate(input string) Promise~string~
        +Base64EncodeText(input string) Promise~string~
        +Base64DecodeText(input string) Promise~string~
        +Base64EncodeFile(filePath string) Promise~string~
        +Base64DecodeFile(filePath string, outputPath string) Promise~string~
        +TimestampToDate(timestamp number, unit string) Promise~string~
        +DateToTimestamp(dateStr string, timezone string) Promise~number~
        +MultiTimezone(timestamp number, unit string) Promise~TimezoneResult[]~
        +YamlFormat(input string, indent int) Promise~string~
        +YamlValidate(input string) Promise~string~
        +YamlToJSON(input string) Promise~string~
        +XmlFormat(input string, indent int) Promise~string~
        +XmlMinify(input string) Promise~string~
        +XmlValidate(input string) Promise~string~
        +RandomGenerate(params RandomParams) Promise~string[]~
        +CronParse(expression string) Promise~CronParseResult~
        +CronValidate(expression string) Promise~string~
        +CronNextN(expression string, count int) Promise~string[]~
        +ClipboardWrite(text string) Promise~void~
        +GetDataDir() Promise~string~
        +GetToolList() Promise~ToolMeta[]~
        +GetAppVersion() Promise~string~
    }

    class WailsJSModels {
        <<generated>>
        +class RandomParams
        +class TimezoneResult
        +class CronParseResult
        +class ToolMeta
        +class ActionDef
    }

    WailsJSGoMainApp --> App : Wails runtime з»‘е®ҡи°ғз”Ё
    WailsJSModels --> RandomParams : TS зұ»еһӢе®ҡд№үжҳ е°„

    %% ===== еүҚз«Ҝдҫ§: Zustand Store =====
    class ToolStore {
        -ToolId currentTool
        -string input
        -string output
        -string error
        -bool loading
        +setCurrentTool(ToolId) void
        +setInput(string) void
        +setOutput(string) void
        +setError(string) void
        +setLoading(bool) void
        +clear() void
    }

    class HistoryStore {
        -HistoryRecord[] records
        +addRecord(HistoryRecord) void
        +getRecords(ToolId) HistoryRecord[]
        +clearRecords() void
    }

    class ThemeStore {
        -string theme
        +setTheme(string) void
        +toggleTheme() void
    }

    %% ===== еүҚз«Ҝдҫ§: Hooks =====
    class useGoMethod {
        +call(args) Promise~T~
        +loading bool
    }

    class useClipboard {
        +copy(text) Promise~void~
        +copied bool
    }

    useGoMethod --> ToolStore : updates loading/error/output
    useGoMethod --> WailsJSGoMainApp : imports Go methods
    useClipboard --> WailsJSGoMainApp : ClipboardWrite

    %% ===== еүҚз«Ҝдҫ§: з»„д»¶ =====
    class AppLayout {
        -bool sidebarCollapsed
        +render() JSX
    }

    class Sidebar {
        -ToolId selectedTool
        -bool collapsed
        +onToolSelect(ToolId) void
        +toggleCollapse() void
        +render() JSX
    }

    class MainContent {
        +render() JSX
    }

    class StatusBar {
        +render() JSX
    }

    class InputArea {
        -string value
        +onChange(string) void
        +render() JSX
    }

    class FileDropArea {
        -string filePath
        +onDrop(File) void
        +onSelectFile() void
        +render() JSX
    }

    class OutputArea {
        -string result
        -string error
        +render() JSX
    }

    class ActionBar {
        -ActionDef[] actions
        +onActionClick(string) void
        +render() JSX
    }

    class ErrorDisplay {
        -string errorMessage
        -int errorLine
        +render() JSX
    }

    class CopyButton {
        +onClick() void
        +render() JSX
    }

    AppLayout --> Sidebar : contains
    AppLayout --> MainContent : contains
    AppLayout --> StatusBar : contains

    %% ===== е·Ҙе…·йЎөйқўз»„д»¶ =====
    class JsonTool {
        +render() JSX
    }
    class Base64Tool {
        -string mode
        +render() JSX
    }
    class TimestampTool {
        -string direction
        -string unit
        +render() JSX
    }
    class YamlTool {
        +render() JSX
    }
    class XmlTool {
        +render() JSX
    }
    class RandomTool {
        -int length
        -CharsetFlags charset
        -int count
        +render() JSX
    }
    class CronTool {
        +render() JSX
    }

    JsonTool --> InputArea : uses
    JsonTool --> ActionBar : uses
    JsonTool --> OutputArea : uses
    JsonTool --> ErrorDisplay : uses
    JsonTool --> useGoMethod : uses (JsonFormat/Minify/Validate)

    Base64Tool --> InputArea : uses (text mode)
    Base64Tool --> FileDropArea : uses (file mode)
    Base64Tool --> ActionBar : uses
    Base64Tool --> OutputArea : uses
    Base64Tool --> useGoMethod : uses (Base64EncodeText/EncodeFile)

    TimestampTool --> InputArea : uses
    TimestampTool --> ActionBar : uses
    TimestampTool --> OutputArea : uses
    TimestampTool --> useGoMethod : uses (TimestampToDate/DateToTimestamp/MultiTimezone)

    YamlTool --> InputArea : uses
    YamlTool --> ActionBar : uses
    YamlTool --> OutputArea : uses
    YamlTool --> useGoMethod : uses (YamlFormat/Validate/ToJSON)

    XmlTool --> InputArea : uses
    XmlTool --> ActionBar : uses
    XmlTool --> OutputArea : uses
    XmlTool --> useGoMethod : uses (XmlFormat/Minify/Validate)

    RandomTool --> ActionBar : uses
    RandomTool --> OutputArea : uses
    RandomTool --> useGoMethod : uses (RandomGenerate)

    CronTool --> InputArea : uses
    CronTool --> ActionBar : uses
    CronTool --> OutputArea : uses
    CronTool --> useGoMethod : uses (CronParse/Validate/NextN)

    MainContent --> JsonTool : renders
    MainContent --> Base64Tool : renders
    MainContent --> TimestampTool : renders
    MainContent --> YamlTool : renders
    MainContent --> XmlTool : renders
    MainContent --> RandomTool : renders
    MainContent --> CronTool : renders

    Sidebar --> ToolStore : reads currentTool
